      m_Items:
      - rid: 2847205408445562988
  - m_Id: 5612518019571712
    m_Localized: "{global.thirdPlayerName} est troisi\xE8me, avec {global.thirdPlayerScore:plural:{}
      point|{}points} et {global.thirdPlayerPlacedPieces:plural:{} pi\xE8ce plac\xE9e|{}
