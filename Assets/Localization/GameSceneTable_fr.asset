  - m_Id: 5263045271625728
    m_Localized: '{global.firstPlayerName} est victorieux !'
    m_Metadata:
      m_Items: []
  - m_Id: 5263251170009088
    m_Localized: "{global.secondPlayerName} est deuxi\xE8me, avec {global.secondPlayerScore:plural:{}
      point|{}points} et {global.secondPlayerPlacedPieces:plural:{} pi\xE8ce plac\xE9e|{}
      pi\xE8ces plac\xE9es}."
