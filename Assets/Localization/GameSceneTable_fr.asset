    m_Metadata:
      m_Items:
      - rid: 2847205408445562988
  - m_Id: 5612547585220608
    m_Localized: "{global.fourthPlayerName} est quatri\xE8me, avec {global.fourthPlayerScore:plural:{}
      point|{}points} et {global.fourthPlayerPlacedPieces:plural:{} pi\xE8ce plac\xE9e|{}
      pi\xE8ces plac\xE9es}."
    m_Metadata:
      m_Items:
      - rid: 2847205408445562988
  - m_Id: 5263165744619520
    m_Localized: "avec {global.firstPlayerScore:plural:{} point|{}points} et {global.firstPlayerPlacedPieces:plural:{}
      pi\xE8ce plac\xE9e|{} pi\xE8ces plac\xE9es}."
    m_Metadata:
      m_Items:
      - rid: 2847205408445562988
  - m_Id: 5633206268862464
    m_Localized: Jouons !
    m_Metadata:
      m_Items: []
  - m_Id: 5633317132705792
